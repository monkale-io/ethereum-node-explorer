    "cypress": "^15.12.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "hardhat": "^3.2.0",
    "jsdom": "^29.0.0",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.24.0",
