{
  "name": "ethereum-node-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "npm run lint && npm run test:coverage && npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "start-server-and-test 'npx hardhat node' http://127.0.0.1:8545 'start-server-and-test dev http://localhost:5173 \"cypress run\"'",
    "cypress:open": "cypress open"
  },
